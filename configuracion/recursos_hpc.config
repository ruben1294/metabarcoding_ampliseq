/*
 * =============================================================================
 *  recursos_hpc.config
 * -----------------------------------------------------------------------------
 *  Recursos para correr en un clúster con SLURM: Nextflow manda cada tarea a la
 *  cola en vez de correrla aquí. Trae los valores del servidor de OMICA (CICESE).
 *  Lo aplica el script 03 con  -profile docker -c este_archivo.
 *
 *  Modelo en OMICA: el job maestro (Nextflow) corre en uno de nodo5/27/28 (lo
 *  elige scripts/lanzar_hpc.sh) y solo orquesta. Cada tarea se manda a SLURM y
 *  corre con Docker en nodo27 y nodo28, fijados con --nodelist.
 * =============================================================================
 */

// Cada tarea se envía como un trabajo de SLURM. 'queue' es la partición y
// 'clusterOptions' la cuenta y el fijado de nodos. --nodelist limita las tareas a
// los nodos que tienen el motor de contenedor (SLURM elige uno). Con Docker son
// nodo27 y nodo28; si cambias a apptainer/singularity, ajústalo a los nodos que lo
// tengan (revísalo con el script 02 o 'srun -w <nodo> apptainer --version').
// 'resourceLimits' es el techo por tarea (un nodo: 24 CPU, 120 GB).
process {
    executor = 'slurm'
    queue = 'cicese'
    // partición / cola
    clusterOptions = '--account=metagenomica --nodelist=nodo27,nodo28 --exclusive=user'
    // cuenta de SLURM y nodos con el motor. --exclusive=user aparta el nodo para tu
    // usuario (ningún otro usuario entra mientras corres) pero deja que tus propios
    // jobs hijos compartan el nodo. Usa '--exclusive' a secas si quieres el nodo
    // entero por tarea (solo 2 tareas a la vez, una por nodo).

    // Techo por tarea = el nodo entero (24 CPU, 120 GB). Ojo: resourceLimits NO pide
    // recursos, solo recorta. Cuánto pide cada tarea lo fijan las withLabel de abajo;
    // por eso aquí dejamos el tope alto, para no estrangular a las etapas pesadas.
    resourceLimits = [cpus: 24, memory: '120.GB', time: '140.h']
    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 140, 143, 247] ? 'retry' : 'finish' }
    maxRetries = 2

    // Recursos por etapa según la etiqueta (label) que nf-core/ampliseq le pone a cada
    // proceso. Verificado contra ampliseq 2.17.0 (modules/). Mismo enfoque que el
    // perfil de DRAM2 en msc_archaea (withLabel:process_*).
    //
    // Cuántas tareas caben por nodo = 24 / (CPU que pide la tarea), limitado también por
    // la RAM (120 GB): 6 CPU/30 GB -> 4 por nodo; 12 CPU/60 GB -> 2; 24 CPU -> el nodo
    // entero. Fijamos cpus (empaque predecible) y dejamos que la RAM escale con los
    // reintentos (task.attempt) por si una tarea muere por falta de memoria; el techo
    // de resourceLimits recorta esa escalada al tamaño del nodo.
    withLabel: process_single {
        cpus = 1
        memory = { 6.GB * task.attempt }
    }
    withLabel: process_low {
        cpus = 2
        memory = { 12.GB * task.attempt }
    }
    withLabel: process_medium {
        cpus = 6
        memory = { 30.GB * task.attempt }   // 4 por nodo
    }
    withLabel: process_high {
        cpus = 12
        memory = { 60.GB * task.attempt }   // compute pesado (dada2, mafft): 2 por nodo
    }
    withLabel: process_huge {
        cpus = 24
        memory = 120.GB                       // qiime2 classify/train: el nodo entero
    }
    // Labels modificadores (cada uno toca una sola dimensión): process_medium_memory
    // (50 GB), process_long (solo time), process_cpu_single (1 CPU). Se quedan con los
    // valores de ampliseq, recortados por resourceLimits. process_high_memory existe en
    // su base.config pero ningún proceso la usa en 2.17.0, por eso no la redefinimos.
}

// 'queueSize' = cuántos trabajos pueden estar en la cola a la vez. Con 4 tareas por
// nodo y 2 nodos (nodo27, nodo28) el tope es 8; SLURM las empaca según los CPU/RAM
// que pida cada una. 'submitRateLimit' evita saturar al planificador al enviarlos.
executor {
    queueSize = 8
    submitRateLimit = '10/1min'
}

// Opciones de Docker (solo aplican con -profile docker). '-u' mapea tu usuario
// dentro del contenedor para que los archivos en LUSTRE no queden como root.
docker {
    runOptions = '-u $(id -u):$(id -g)'
}

// Apptainer/Singularity (con -profile apptainer o -profile singularity). Es lo
// recomendado en un HPC sin internet: las imágenes .sif viven en la caché que
// apunta NXF_APPTAINER_CACHEDIR / NXF_SINGULARITY_CACHEDIR (el script 03 la fija en
// LUSTRE compartido, precargada por scripts/precargar_imagenes_apptainer_hpc.sh). 'autoMounts'
// monta dentro del contenedor las rutas del host que la tarea necesita (incluidas
// las bases de datos en LUSTRE).
apptainer {
    autoMounts = true
}
singularity {
    autoMounts = true
}
