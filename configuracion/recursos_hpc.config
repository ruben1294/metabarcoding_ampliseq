/*
 * =============================================================================
 *  recursos_hpc.config
 * -----------------------------------------------------------------------------
 *  Recursos para correr en un clúster con SLURM: Nextflow manda cada tarea a la
 *  cola en vez de correrla aquí. Trae los valores del servidor de OMICA (CICESE).
 *  Lo aplica el script 03 con  -profile docker -c este_archivo.
 *
 *  Modelo en OMICA: el job maestro (Nextflow) corre en uno de nodo5/27/28 (lo
 *  elige scripts/lanzar_hpc.sh) y solo orquesta. Cada tarea se manda a SLURM y
 *  corre con Docker en nodo27 y nodo28, fijados con --nodelist.
 * =============================================================================
 */

// Cada tarea se envía como un trabajo de SLURM. 'queue' es la partición y
// 'clusterOptions' la cuenta y el fijado de nodos. --nodelist limita las tareas a
// los nodos que tienen el motor de contenedor (SLURM elige uno). Con Docker son
// nodo27 y nodo28; si cambias a apptainer/singularity, ajústalo a los nodos que lo
// tengan (revísalo con el script 02 o 'srun -w <nodo> apptainer --version').
// 'resourceLimits' es el techo por tarea (un nodo: 24 CPU, 120 GB).
process {
    executor = 'slurm'
    queue = 'cicese'
    // partición / cola
    clusterOptions = '--account=metagenomica --nodelist=nodo27,nodo28'
    // cuenta de SLURM y nodos con el motor. Para apartar el nodo entero por tarea
    // añade --exclusive (más aislamiento, pero solo 2 tareas a la vez).

    resourceLimits = [cpus: 24, memory: '120.GB', time: '140.h']
    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 140, 143, 247] ? 'retry' : 'finish' }
    maxRetries = 2
}

// 'queueSize' = cuántos trabajos pueden estar en la cola a la vez. Con solo dos
// nodos de cómputo no conviene pasarse; la RAM se reparte entre las tareas
// activas. 'submitRateLimit' evita saturar al planificador al enviarlos.
executor {
    queueSize = 4
    submitRateLimit = '10/1min'
}

// Opciones de Docker (solo aplican con -profile docker). '-u' mapea tu usuario
// dentro del contenedor para que los archivos en LUSTRE no queden como root.
docker {
    runOptions = '-u $(id -u):$(id -g)'
}

// Apptainer/Singularity (con -profile apptainer o -profile singularity). Es lo
// recomendado en un HPC sin internet: las imágenes .sif viven en la caché que
// apunta NXF_APPTAINER_CACHEDIR / NXF_SINGULARITY_CACHEDIR (el script 03 la fija en
// LUSTRE compartido, precargada por scripts/precargar_imagenes_hpc.sh). 'autoMounts'
// monta dentro del contenedor las rutas del host que la tarea necesita (incluidas
// las bases de datos en LUSTRE).
apptainer {
    autoMounts = true
}
singularity {
    autoMounts = true
}
